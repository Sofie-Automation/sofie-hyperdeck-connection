{
  "name": "hyperdeck-connection",
  "version": "3.0.0-0",
  "description": "Typescript Node.js library for connecting with a BlackmagicDesign's HyperDeck devices.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sofie-Automation/sofie-hyperdeck-connection.git"
  },
  "bugs": {
    "url": "https://github.com/Sofie-Automation/sofie-hyperdeck-connection/issues"
  },
  "homepage": "https://github.com/Sofie-Automation/sofie-hyperdeck-connection#readme",
  "contributors": [
    {
      "name": "Julian Waller",
      "email": "julian@superfly.tv",
      "url": "https://superfly.tv"
    },
    {
      "name": "Mint de Wit",
      "email": "mint@superfly.tv",
      "url": "https://superfly.tv"
    }
  ],
  "scripts": {
    "prepare": "husky",
    "build": "rimraf dist && run build:main",
    "build:main": "tsc -p tsconfig.build.json",
    "lint:raw": "eslint",
    "lint": "run lint:raw .",
    "lint-fix": "run lint --fix",
    "unit": "jest",
    "test": "run lint && run unit",
    "test:integration": "run lint && jest --config=jest-integration.config.js",
    "watch": "jest --watch",
    "cov": "jest --coverage && open-cli coverage/lcov-report/index.html",
    "cov-open": "open-cli coverage/lcov-report/index.html",
    "docs": "run docs:html && open-cli docs/index.html",
    "docs:test": "run docs:html",
    "docs:html": "typedoc --entryPoints src/index.ts --excludePrivate --theme default --out docs",
    "docs:json": "typedoc --json docs/typedoc.json --entryPoints src/index.ts",
    "changelog": "sofie-version",
    "validate:dependencies": "yarn npm audit --environment production && run license-validate",
    "validate:dev-dependencies": "yarn npm audit",
    "license-validate": "sofie-licensecheck --allowPackages caniuse-lite@1.0.30001312"
  },
  "engines": {
    "node": ">=22.22"
  },
  "files": [
    "/dist",
    "/CHANGELOG.md",
    "/README.md",
    "/LICENSE"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sofie-automation/code-standard-preset": "~3.2.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.21",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.7",
    "open-cli": "^9.0.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "typedoc": "^0.28.19",
    "typescript": "~6.0.3"
  },
  "keywords": [
    "blackmagic",
    "bmd",
    "hyperdeck",
    "video",
    "typescript",
    "javascript",
    "open",
    "source"
  ],
  "prettier": "@sofie-automation/code-standard-preset/.prettierrc.json",
  "lint-staged": {
    "*.{css,json,md,scss}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "yarn lint:raw --fix"
    ]
  },
  "packageManager": "yarn@4.17.0"
}
